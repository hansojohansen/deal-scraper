# Copy this file to .env and fill in your values
# Never commit .env to git

# Supabase PostgreSQL connection string
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/deal_scraper

# Gemini Flash free tier (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# SMTP for deal alert emails (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# CORS: comma-separated allowed origins for the frontend
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","capacitor://localhost"]
